  stat4LabelEn    String   @default("Years of Legacy")
  stat4LabelBn    String   @default("বছরের ঐতিহ্য")
  
  // New Fields added for Full Site Customization
  logoUrl            String?   @default("/images/crest.png")
  
  contactAddressEn   String?   @default("Cantonment Road, Dhaka, Bangladesh")
  contactAddressBn   String?   @default("ক্যান্টনমেন্ট রোড, ঢাকা, বাংলাদেশ")
  contactPhoneEn     String?   @default("+880 1700 000000")
  contactPhoneBn     String?   @default("+৮৮০ ১৭০০ ০০০০০০")
  contactEmail       String?   @default("info@rafiqrajucadet.edu.bd")
  
  aboutTitleEn       String?   @default("Who We Are")
  aboutTitleBn       String?   @default("আমাদের সম্পর্কে")
  aboutTextEn        String?   @default("Shaping disciplined, knowledgeable and honourable leaders since 1998.")
  aboutTextBn        String?   @default("১৯৯৮ সাল থেকে শৃঙ্খলাপরায়ণ, জ্ঞানী এবং সম্মানজনক নেতা তৈরি করা হচ্ছে।")
  aboutImageUrl      String?   @default("/images/campus.jpg")
  aboutPillars       String?   // JSON stringified array of objects
  
  academicsTitleEn   String?   @default("A Curriculum Built for Leaders")
  academicsTitleBn   String?   @default("নেতৃত্ব তৈরির কারিকুলাম")
  academicsTextEn    String?   @default("Our comprehensive academic structure bridges national curriculum with military discipline.")
  academicsTextBn    String?   @default("আমাদের ব্যাপক একাডেমিক কাঠামো জাতীয় শিক্ষাক্রমকে সামরিক শৃঙ্খলার সাথে যুক্ত করে।")
  academicsPrograms  String?   // JSON stringified array
  
  campusTitleEn      String?   @default("Where Character Is Forged Daily")
  campusTitleBn      String?   @default("যেখানে প্রতিদিন চরিত্র গঠন হয়")
  campusTextEn       String?   @default("Life at Rafiq Raju Cadet School is a rigorous balance of academics, physical training, and moral development.")
