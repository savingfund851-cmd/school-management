  campusItems        String?   // JSON stringified array
  
  admissionsTitleEn  String?   @default("Take The First Step")
  admissionsTitleBn  String?   @default("প্রথম পদক্ষেপ নিন")
  admissionsTextEn   String?   @default("Join a legacy of excellence. We select candidates who demonstrate academic potential, physical fitness, and strong moral character.")
  admissionsTextBn   String?   @default("উৎকর্ষের ঐতিহ্যে যোগ দিন। আমরা এমন প্রার্থীদের নির্বাচন করি যারা শিক্ষাগত সম্ভাবনা, শারীরিক সুস্থতা এবং দৃঢ় নৈতিক চরিত্র প্রদর্শন করে।")
  admissionsSteps    String?   // JSON stringified array
  
  footerAboutEn      String?   @default("Shaping disciplined, knowledgeable and honourable leaders since 1998.")
  footerAboutBn      String?   @default("১৯৯৮ সাল থেকে শৃঙ্খলাপরায়ণ, জ্ঞানী এবং সম্মানজনক নেতা তৈরি করা হচ্ছে।")

  campusImage1Url    String?   @default("/images/campus.jpg")
