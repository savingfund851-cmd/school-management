// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    // "superadmin" | "admin" | "teacher" | "student"
  permissions  String?   // JSON array of strings
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relations
  student      Student?
  teacher      Teacher?
  Notice       Notice[]
  Admission    Admission[] @relation("ReviewedBy")
}

model Student {
  id             String       @id @default(uuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  rollNo         String
  classId        String
  class          Class        @relation(fields: [classId], references: [id])
  section        String
  dob            String
  gender         String
  guardianName   String
  guardianPhone  String
  address        String
  photoUrl       String?
  admissionDate  DateTime     @default(now())
  status         String       @default("active") // "active" | "inactive"
  
  // Relations
  attendance     Attendance[]
  Result         Result[]
  Fee            Fee[]
}

model Teacher {
  id           String       @id @default(uuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  employeeId   String       @unique
  subject      String
  phone        String
  address      String
  joiningDate  DateTime     @default(now())
  status       String       @default("active") // "active" | "inactive"
  
  // Relations
  Class        Class[]
  Attendance   Attendance[]
}

model Class {
  id           String       @id @default(uuid())
  name         String       // "Class 1" to "Class 10"
  section      String
  teacherId    String?
  teacher      Teacher?     @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  academicYear String
  
  // Relations
  Student      Student[]
  Attendance   Attendance[]
  Exam         Exam[]
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  status    String   // "present" | "absent" | "late"
  markedById String
  markedBy  Teacher  @relation(fields: [markedById], references: [id])
}

model Exam {
  id           String   @id @default(uuid())
  name         String   // e.g., "Midterm Exam", "Final Exam"
  classId      String
  class        Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject      String
  examDate     DateTime
  totalMarks   Int
  academicYear String
  
  // Relations
  Result       Result[]
}

model Result {
  id            String   @id @default(uuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marksObtained Float
  grade         String
  remarks       String?
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  content     String
  targetRole  String   // "all" | "teacher" | "student"
  publishedById String
  publishedBy User     @relation(fields: [publishedById], references: [id])
  publishedAt DateTime @default(now())
  isActive    Boolean  @default(true)
}

model Admission {
  id             String   @id @default(uuid())
  applicantName  String
  dob            String
  applyingClass  String
  guardianName   String
  guardianPhone  String
  email          String
  documentsUrl   String?
  status         String   @default("pending") // "pending" | "approved" | "rejected"
  appliedAt      DateTime @default(now())
  reviewedById   String?
  reviewedBy     User?    @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
}

model Fee {
  id        String    @id @default(uuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount    Float
  feeType   String    // "tuition" | "exam" | "admission" | "other"
  dueDate   DateTime
  paidDate  DateTime?
  status    String    @default("unpaid") // "paid" | "unpaid" | "partial"
}

